{
    "$schema": "https://unpkg.com/knip@latest/schema.json",
    "entry": [
        "src/components/ui/**/*.{ts,tsx}",
        "src/lib/**/*.{ts,tsx}",
        "src/data/**/*.{ts,tsx}",
        "src/trpc/**/*.{ts,tsx}",
        "src/app/\\(app\\)/prop-calculator/_components/**/*.{ts,tsx}",
        "src/server/db/relations.ts",
        "src/server/db/seeds/**/*.ts"
    ],
    "ignore": [
        "src/app/(app)/_components/brand/GlitchBrand.tsx",
        "src/app/(app)/_components/Socials.tsx"
    ],
    "ignoreDependencies": [
        "@types/bcryptjs",
        "baseline-browser-mapping",
        "caniuse-lite",
        "cssnano",
        "cssnano-preset-default",
        "sharp"
    ]
}
