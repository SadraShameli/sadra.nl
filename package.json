        "lint-staged": "^17.0.7",
        "pino-pretty": "^13.1.3",
        "postcss": "^8.5.15",
        "postcss-scss": "^",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "sass": "^1.100.0",
        "sort-package-json": "^4.0.0",
        "stylelint": "^17.13.0",
        "stylelint-config-recommended-scss": "^17.0.1",
        "stylelint-order": "^8.1.1",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vitest": "^4.1.8"
    },
    "trustedDependencies": [
