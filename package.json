{
    "name": "sadra.nl",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "next build",
        "check": "bun run format:write && bun run lint && bun run stylelint && bun run typecheck && bun run knip",
        "db:bootstrap": "bun --env-file .env ./src/server/db/bootstrap.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "bun run db:bootstrap && drizzle-kit push",
        "db:seed": "bun --env-file .env ./src/server/db/seed.ts",
        "db:studio": "drizzle-kit studio",
        "dev": "next dev",
        "format": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,mdx,md,json,yml,yaml}\"",
        "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,mdx,md,json,yml,yaml}\"",
        "knip": "knip",
        "lint": "eslint .",
        "ncu": "bunx npm-check-updates --interactive --format group",
        "prepare": "husky",
        "preview": "next build && next start",
        "start": "next start",
        "stylelint": "stylelint '**/*.{css,scss}'",
        "stylelint:fix": "stylelint '**/*.{css,scss}' --fix --quiet",
        "test": "vitest run",
        "test:e2e": "playwright test",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "verify": "bun run format && bun run lint && bun run stylelint && bun run typecheck && bun run knip && bun run test",
        "verify:build": "SKIP_ENV_VALIDATION=true next build"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{css,scss}": [
            "stylelint --fix --quiet"
        ],
        "*.{md,mdx,yml,yaml}": [
            "prettier --write"
        ],
        "*.json": [
            "prettier --write"
        ],
        "package.json": [
            "sort-package-json"
        ]
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@hookform/resolvers": "^5.4.0",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-progress": "^1.1.8",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toggle": "^1.1.10",
        "@radix-ui/react-toggle-group": "^1.1.11",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@react-email/components": "^1.0.12",
        "@react-email/render": "^2.0.8",
        "@react-pdf/renderer": "^4.5.1",
        "@sentry/nextjs": "^10.53.1",
        "@t3-oss/env-nextjs": "^0.13.11",
        "@tanstack/react-query": "^5.100.14",
        "@tanstack/react-table": "^8.21.3",
        "@trpc/client": "^11.17.0",
        "@trpc/react-query": "^11.17.0",
        "@trpc/server": "^11.17.0",
        "@types/zxcvbn": "^4.4.5",
        "@vercel/functions": "^3.6.0",
        "baseline-browser-mapping": "^2.10.32",
        "better-auth": "^1.6.11",
        "caniuse-lite": "^1.0.30001793",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.3.0",
        "drizzle-orm": "^0.45.2",
        "drizzle-zod": "^0.8.3",
        "embla-carousel-autoplay": "^8.6.0",
        "embla-carousel-react": "^8.6.0",
        "framer-motion": "^12.40.0",
        "geist": "^1.7.1",
        "html-react-parser": "^6.1.2",
        "lettermint": "^2.0.0",
        "lucide-react": "^1.16.0",
        "next": "^16.2.6",
        "next-themes": "^0.4.6",
        "papaparse": "^5.5.3",
        "pg": "^8.21.0",
        "pino": "^10.3.1",
        "postgres": "^3.4.9",
        "react": "^19.2.6",
        "react-day-picker": "^10.0.1",
        "react-dom": "^19.2.6",
        "react-hook-form": "^7.76.1",
        "recharts": "3.8.1",
        "resend": "^6.12.3",
        "server-only": "^0.0.1",
        "sharp": "^0.34.5",
        "sonner": "^2.0.7",
        "superjson": "^2.2.6",
        "tw-animate-css": "^1.4.0",
        "ua-parser-js": "^2.0.10",
        "zod": "^4.4.3",
        "zxcvbn": "^4.4.2"
    },
    "devDependencies": {
        "@next/eslint-plugin-next": "^16.2.6",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4.3.0",
        "@tailwindcss/typography": "^0.5.19",
        "@types/node": "^25.9.1",
        "@types/papaparse": "^5.5.2",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "@vitest/coverage-v8": "^4.1.7",
        "cssnano": "^8.0.1",
        "cssnano-preset-default": "^8.0.1",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.4.0",
        "eslint-plugin-drizzle": "^0.2.3",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-perfectionist": "^5.9.0",
        "eslint-plugin-promise": "^7.3.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-unicorn": "^64.0.0",
        "happy-dom": "^20.9.0",
        "husky": "^9.1.7",
        "knip": "^6.14.2",
        "lint-staged": "^17.0.5",
        "pino-pretty": "^13.1.3",
        "postcss": "^8.5.15",
        "postcss-scss": "^4.0.9",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "sass": "^1.100.0",
        "sort-package-json": "^3.6.1",
        "stylelint": "^17.12.0",
        "stylelint-config-recommended-scss": "^17.0.1",
        "stylelint-order": "^8.1.1",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.4",
        "vitest": "^4.1.7"
    },
    "trustedDependencies": [
        "@vercel/speed-insights"
    ]
}
