{
    "name": "sadra.nl",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "next build",
        "check": "next lint && tsc --noEmit",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:seed": "bun --env-file .env ./src/server/db/seed.ts",
        "db:studio": "drizzle-kit studio",
        "dev": "next dev",
        "format": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
        "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
        "ncu": "bunx npm-check-updates --interactive --format group",
        "prepare": "husky",
        "preview": "next build && next start",
        "start": "next start",
        "stylelint": "stylelint '**/*.{css,scss}'",
        "stylelint:fix": "stylelint '**/*.{css,scss}' -- --fix --quiet",
        "typecheck": "tsc --noEmit"
    },
