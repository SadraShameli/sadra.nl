{
    "name": "sadra.nl",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "next build",
        "check": "bun run format:write && bun run lint && bun run stylelint && bun run typecheck && bun run knip",
        "cli": "bun --env-file .env ./src/cli/index.ts",
        "db:bootstrap": "bun --env-file .env ./src/server/db/bootstrap.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "bun run db:bootstrap && drizzle-kit push",
        "db:seed": "bun --env-file .env ./src/cli/index.ts seed run",
        "db:studio": "drizzle-kit studio",
        "dev": "next dev",
        "format": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,mdx,md,json,yml,yaml}\"",
        "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,mdx,md,json,yml,yaml}\"",
        "knip": "knip",
        "lint": "eslint . --fix",
        "ncu": "bunx npm-check-updates --interactive --format group",
        "prepare": "husky",
        "preview": "next build && next start",
        "start": "next start",
        "stylelint": "stylelint '**/*.{css,scss}'",
        "stylelint:fix": "stylelint '**/*.{css,scss}' --fix --quiet",
        "test": "vitest run",
        "test:e2e": "playwright test",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "verify": "bun run format:write && bun run lint && bun run stylelint && bun run typecheck && bun run knip && bun run test",
        "verify:build": "SKIP_ENV_VALIDATION=true next build"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{css,scss}": [
            "stylelint --fix --quiet"
        ],
        "*.{md,mdx,yml,yaml}": [
            "prettier --write"
        ],
        "*.json": [
            "prettier --write"
        ],
        "package.json": [
            "sort-package-json"
        ]
    },
    "dependencies": {
        "@clack/prompts": "^1.5.1",
        "@dnd-kit/core": "^",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@hookform/resolvers": "^5.4.0",
        "@radix-ui/react-alert-dialog": "^1.1.16",
