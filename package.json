        "@tailwindcss/postcss": "^4.3.0",
        "@tailwindcss/typography": "^0.5.20",
        "@types/node": "^25.9.2",
        "@types/papaparse": "^5.5.2",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "@vitest/coverage-v8": "^4.1.8",
        "cssnano": "^8.0.1",
        "cssnano-preset-default": "^8.0.1",
